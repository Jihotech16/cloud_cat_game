{
  "name": "cloud-cat-jump",
  "version": "1.0.0",
  "description": "구름 위를 뛰어올라 하늘 끝까지 올라가는 고양이 점프 게임입니다.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-www.mjs",
    "icons": "node scripts/gen-icons.mjs",
    "sync": "npm run build && cap sync",
    "add:android": "cap add android",
    "add:ios": "cap add ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "npm run sync && cap run android",
    "run:ios": "npm run sync && cap run ios"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jihotech16/cloud_cat_game.git"
  },
  "keywords": ["game", "capacitor", "pwa", "cat"],
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "playwright-core": "^1.61.1"
  }
}

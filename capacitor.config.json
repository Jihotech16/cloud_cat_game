{
  "appId": "com.jihotech.cloudcatjump",
  "appName": "Cloud Cat Jump",
  "webDir": "www",
  "backgroundColor": "#6ec6ff",
  "android": {
    "backgroundColor": "#6ec6ff"
  },
  "ios": {
    "backgroundColor": "#6ec6ff",
    "contentInset": "always"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#6ec6ff",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
